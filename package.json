{
	"name": "spicy-tools",
	"version": "0.1.0",
	"description": "Frontmatter dropdowns with inheritance and folder-based Kanban boards for Obsidian",
	"main": "main.js",
	"scripts": {
		"build:css": "node scripts/build-css.js",
		"dev": "node scripts/build-css.js && node esbuild.config.mjs",
		"build": "node scripts/build-css.js && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:ui": "node tests/ui/run-tests.mjs",
		"test:ui:stress": "npx playwright test tests/ui/table-dropdowns-stress.test.ts --config tests/ui/playwright.config.ts",
		"test:ui:headed": "npx playwright test --config tests/ui/playwright.config.ts --headed",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"kanban",
		"frontmatter",
		"dropdown"
	],
	"author": "Eddie Hallam",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/state": "^6.5.4",
		"@codemirror/view": "^6.39.11",
		"@playwright/test": "^1.57.0",
		"@types/jest": "^29.5.12",
		"@types/node": "^24.0.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "0.28.0",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^30.2.0",
		"obsidian": "latest",
		"playwright": "^1.58.0",
		"ts-jest": "^29.1.2",
		"tslib": "2.8.1",
		"typescript": "5.9.3"
	}
}
